COMPOSE_PROJECT_NAME=redis-banking-demos
COMPOSE_PROFILES=base
TZ=Europe/Madrid

PUBLIC_HTTP_PORT=80
PUBLIC_HTTPS_PORT=8443

LAB_RUNTIME_ROOT=./runtime
WP_ROOT_HOST_PATH=./runtime/wp-root
MYSQL_ROOT_HOST_PATH=./runtime/mysql
ELASTIC_DATA_HOST_PATH=./runtime/elasticsearch

DOCKER_NETWORK_NAME=wp-poc-net

NGINX_IMAGE=nginx:1.27.5-alpine
PHP_FPM_IMAGE=php:8.2.28-fpm-alpine
PHP_CLI_IMAGE=php:8.2.28-cli-alpine
MYSQL_IMAGE=mysql:8.4.6
ELASTICSEARCH_IMAGE=elasticsearch:8.15.3

WP_ENVIRONMENT_TYPE=staging
WP_DISABLE_ELASTICSEARCH=false
ELASTICSEARCH_URL=http://elastic:9200
