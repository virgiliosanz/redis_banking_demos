# Production example only.
# Do not use this snippet in the local POC.

# Goal:
# - origin only reachable from local tunnel connector or private network
# - no public direct entry to the origin

# If cloudflared runs locally:
# allow 127.0.0.1;
# allow ::1;

# If cloudflared runs on a private network host, allow only that network or IP:
# allow 10.0.0.10;
# allow 10.0.0.0/24;

# deny all;

# Optional pattern:
# move the origin listener to an internal interface only, and let firewall or
# security groups enforce the same boundary outside Nginx.
