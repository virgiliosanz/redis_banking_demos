# Production example only.
# Do not use this snippet in the local POC.

# Trust the real client IP only when the request comes from the local
# cloudflared connector or from an explicitly controlled private network.

set_real_ip_from 127.0.0.1;
set_real_ip_from ::1;

# Add private ranges only if cloudflared runs on another internal host.
# set_real_ip_from 10.0.0.0/8;
# set_real_ip_from 172.16.0.0/12;
# set_real_ip_from 192.168.0.0/16;

real_ip_header CF-Connecting-IP;
real_ip_recursive off;
