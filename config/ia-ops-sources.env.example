# IA-Ops Bootstrap: configuracion no sensible

PROJECT_ROOT=/opt/project
WP_ROOT_HOST_PATH=./runtime/wp-root
REPORT_ROOT=./runtime/reports/ia-ops

# Tail maximo de logs por colector
LOG_TAIL_LINES=500

# Servicios base observados
CONTAINER_LB_NGINX=n9-lb-nginx
CONTAINER_FE_LIVE=n9-fe-live
CONTAINER_FE_ARCHIVE=n9-fe-archive
CONTAINER_BE_ADMIN=n9-be-admin
CONTAINER_DB_LIVE=n9-db-live
CONTAINER_DB_ARCHIVE=n9-db-archive
CONTAINER_ELASTIC=n9-elastic
CONTAINER_CRON_MASTER=n9-cron-master

# Hosts publicos del laboratorio
BASE_URL=http://nuevecuatrouno.test
ARCHIVE_URL=http://archive.nuevecuatrouno.test

# Elasticsearch
EP_SEARCH_ALIAS=n9-search-posts

# Umbrales iniciales de host
HOST_MEMORY_WARNING_PCT=85
HOST_MEMORY_CRITICAL_PCT=92
HOST_DISK_WARNING_PCT=80
HOST_DISK_CRITICAL_PCT=90
HOST_IOWAIT_WARNING_PCT=10
HOST_IOWAIT_CRITICAL_PCT=20

# Umbrales de cron
CRON_WARNING_DELAY_MINUTES=30
CRON_CRITICAL_DELAY_MINUTES=120

# Heartbeats esperados de jobs criticos
CRON_HEARTBEAT_DIR=./runtime/heartbeats
CRON_JOB_EDITORIAL_SYNC=sync-editorial-users
CRON_JOB_PLATFORM_SYNC=sync-platform-config
CRON_JOB_ROLLOVER=rollover-content-year
